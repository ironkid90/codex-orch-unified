{
    "version": "0.2.0",
    "configurations": [
        
        {
            "command": "npm start",
            "name": "Run npm start",
            "request": "launch",
            "type": "node-terminal"
        },
        {
            "name": "Orch: Debug Agent HTTP (Inspector)",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5679
            },
            "preLaunchTask": "Orch: Open Agent Inspector",
            "internalConsoleOptions": "neverOpen",
            "postDebugTask": "Orch: Terminate All Tasks"
        }
    ]
}
