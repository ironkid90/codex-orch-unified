{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Orch: Bootstrap Workspace",
      "type": "shell",
      "command": "npm install && npm run bootstrap",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build"
    },
    {
      "label": "Orch: Doctor",
      "type": "shell",
      "command": "npm run doctor",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Orch: Build All",
      "type": "shell",
      "command": "npm run build:all",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Orch: Dev GUI",
      "type": "shell",
      "command": "npm run dev:gui",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".*"
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "ready - started server|Ready in|Local:"
        }
      }
    },
    {
      "label": "Orch: Dev Agent Server",
      "type": "shell",
      "command": "npm run dev:agent",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".*"
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Application startup complete|running on|Started server process"
        }
      }
    },
    {
      "label": "Orch: Dev Full Stack",
      "type": "shell",
      "command": "npm run dev:all",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".*"
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "ready - started server|Application startup complete|running on|Local:"
        }
      }
    },
    {
      "label": "Orch: Swarm CLI (local)",
      "type": "shell",
      "command": "npm run swarm:run -- --mode local --max-rounds 3",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Orch: Models Discover",
      "type": "shell",
      "command": "npm run models:discover",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Orch: Models Optimize",
      "type": "shell",
      "command": "npm run models:optimize",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Orch: Models Evaluate",
      "type": "shell",
      "command": "npm run models:evaluate",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Orch: Batch Generate",
      "type": "shell",
      "command": "npm run batch:gen",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Orch: Batch Run",
      "type": "shell",
      "command": "npm run batch:run",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Orch: Debug Agent HTTP (Inspector)",
      "type": "shell",
      "command": "${command:python.interpreterPath} -m debugpy --listen 127.0.0.1:5679 -m agentdev run \"${workspaceFolder}/foundry_agents/workflow_server.py\" --verbose --port 8087",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".*"
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Application startup complete|running on|Started server process"
        }
      }
    },
    {
      "label": "Orch: Open Agent Inspector",
      "type": "shell",
      "command": "echo '${input:openAgentInspectorFoundry}'",
      "presentation": {
        "reveal": "never"
      },
      "dependsOn": [
        "Orch: Debug Agent HTTP (Inspector)"
      ]
    },
    {
      "label": "Orch: Terminate All Tasks",
      "type": "shell",
      "command": "echo ${input:terminateFoundry}",
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "openAgentInspectorFoundry",
      "type": "command",
      "command": "ai-mlstudio.openTestTool",
      "args": {
        "triggeredFrom": "tasks",
        "port": 8087
      }
    },
    {
      "id": "terminateFoundry",
      "type": "command",
      "command": "workbench.action.tasks.terminate",
      "args": "terminateAll"
    }
  ]
}
