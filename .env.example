OPENAI_API_KEY=
OPENAI_OAUTH_ACCESS_TOKEN=
SWARM_OPENAI_AUTH_MODE=api_key
OPENAI_SWARM_MODEL=gpt-5.2
SWARM_CODEX_MODEL=codex-5.3
SWARM_MODEL_ROUTING_FILE=config/model-routing.json
SWARM_CODEX_SUPPORTS_MODEL_FLAG=0

# Optional: use Gemini for research augmentation.
# Set SWARM_RESEARCH_PROVIDER=gemini to enable.
SWARM_RESEARCH_PROVIDER=
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_API_KEY=
GEMINI_SWARM_MODEL=gemini-3.1-pro-preview
GEMINI_SWARM_FAST_MODEL=gemini-3.1-flash-preview

# Optional: Google auth for Gemini (instead of API key).
GOOGLE_USE_ADC=0
GOOGLE_OAUTH_ACCESS_TOKEN=
SWARM_MODEL_OPTIMIZER_LIVE_PROBE=0

# Optional runtime overrides
SWARM_CODEX_BIN=codex
SWARM_FORCE_DEMO=0

# Optional: external web research adapter.
SWARM_WEB_SEARCH=0
SWARM_WEB_SEARCH_PROVIDER=bing
SWARM_WEB_SEARCH_MAX_RESULTS=6
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com/search

# Batch multi-agent pipeline
OPENAI_BATCH_MODEL=gpt-4o-mini
BATCH_PROJECT=run1
SHARD_MAX_LINES=10000
UPLOAD_CONCURRENCY=3
POLL_INTERVAL_MS=5000
BATCH_RETRY_MAX_ATTEMPTS=2
BATCH_RETRY_ON_SCHEMA_FAIL=1
BATCH_VALIDATE_MERGE=1
BATCH_RETRY_SHARD_MAX_LINES=10000
SWARM_BATCH_MERGED_FILE=batch/out/merged_output.jsonl

# Microsoft Agent Framework + Azure AI Foundry
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL_DEPLOYMENT_NAME=
